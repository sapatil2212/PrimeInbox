# Database connection string for Prisma (MySQL)
DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# Secret keys for authentication (Generate secure keys in production)
JWT_SECRET="replace-with-secure-32-character-secret"
# Dedicated secret for the isolated Super Admin (/admin) session. MUST differ from JWT_SECRET.
ADMIN_JWT_SECRET="replace-with-a-DIFFERENT-secure-32-character-secret"
SESSION_SECRET="replace-with-secure-session-secret"
ENCRYPTION_KEY="replace-with-64-char-hex-encryption-key"

# Application Config
APP_URL="http://localhost:3000"
NODE_ENV="development"
COOKIE_DOMAIN="localhost"

# Media / File Storage
# Driver: "local" stores files on the server filesystem.
MEDIA_DRIVER="local"
# Absolute path where uploaded files are stored (organized by workspace).
# In local dev, if this path isn't writable it falls back to ./public/uploads automatically.
MEDIA_UPLOAD_PATH="/var/www/storage"
# Public base URL that maps to MEDIA_UPLOAD_PATH (served by your web server / nginx).
MEDIA_PUBLIC_URL="https://primeinbox.online/uploads"

# Payments (Razorpay) — required to accept subscriptions
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# SMTP Mailer Settings for Transactional Emails (OTP, Notifications)
# IMPORTANT: For best deliverability, use your own domain (not @gmail.com)
# See EMAIL_DELIVERABILITY_GUIDE.md for complete setup instructions

# Example with Gmail (Development only - 500 emails/day limit)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"  # Use your actual domain, NOT @gmail.com
SMTP_PASS="xxxx-xxxx-xxxx-xxxx"     # Gmail App Password (16 chars, enable 2FA first)
SMTP_FROM="PrimeInbox"               # Professional sender name (no emojis, no ALL CAPS)
SMTP_BCC=""                          # Optional: BCC address for email monitoring

# For Production: Use SendGrid (recommended), AWS SES, or Mailgun
# See .env.email-examples for detailed provider configurations
# REQUIRED: Set up SPF, DKIM, and DMARC DNS records (see EMAIL_DELIVERABILITY_GUIDE.md)

# Social Authentication OAuth placeholders (for future expansion)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
